# Build outputs
/frontend/dist/
*.tsbuildinfo

# Test / coverage artifacts
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/

# Local dev helpers
start_backend.*
start_frontend.*

# Claude Code harness internals (per-machine state, never source-of-truth).
# Includes the .claude/worktrees/ folder the harness creates when running
# parallel sub-agents in isolated worktrees.
.claude/*
# ...but DO version these shared dev-tooling files (team-wide config):
!.claude/settings.json
!.claude/commands/
!.claude/hooks/
# Keep personal/local overrides out of git:
.claude/settings.local.json

# Graphify knowledge-graph output (generated by `graphify update .`;
# regenerate locally, never source-of-truth -- ~600 generated files).
graphify-out/

# Local-only operational artifacts -- NEVER committed (they clutter the working
# tree + must not be swept into a commit):
#   * backups/      -- prod MongoDB snapshots (e.g. the 2026-06-15 fresh-slate
#     wipe recovery); large local recovery net, kept on disk but out of git.
#   * scripts/_*.py -- one-off underscore-prefixed diagnostic / backup / wipe /
#     reseed / verify scripts run via `railway run`, not part of the app.
#   * mig_*.txt / mig_*_out.txt -- stray migration console dumps.
#   * *TEMPvr_router.py -- a stray editor temp file.
backups/
scripts/_*.py
mig_*.txt
mig_*_out.txt
*TEMPvr_router.py
