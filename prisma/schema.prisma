generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  name       String
  role       String   @default("CATALOG_MANAGER") // ADMIN, DESIGN_MANAGER, CATALOG_MANAGER
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  products   Product[]
}

model Location {
  id                String   @id @default(cuid())
  name              String
  code              String   @unique
  address           String?
  isActive          Boolean  @default(true)
  shopifyLocationId String?  @unique // Shopify location GID for inventory sync
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  users             User[]
  products          ProductLocation[]
  variants          VariantLocation[]
}

model AttributeType {
  id        String   @id @default(cuid())
  name      String   @unique
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  options   AttributeOption[]
}

model AttributeOption {
  id              String        @id @default(cuid())
  attributeTypeId String
  attributeType   AttributeType @relation(fields: [attributeTypeId], references: [id], onDelete: Cascade)
  value           String
  sortOrder       Int           @default(0)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())

  @@unique([attributeTypeId, value])
}

model DiscountRule {
  id                 String   @id @default(cuid())
  category           String   @unique
  discountPercentage Float
  createdAt          DateTime @default(now())
}

// ─────────────────────────────────────────────────────────
// PRODUCT = Parent/Master product (e.g. "BOSS 1234")
// Holds shared attributes: brand, modelNo, shape, material, gender, etc.
// Each unique color+size combo lives in ProductVariant.
// ─────────────────────────────────────────────────────────
model Product {
  id               String   @id @default(cuid())
  category         String   // SPECTACLES, SUNGLASSES, SOLUTIONS
  status           String   @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  shopifyProductId String?
  // Three-role design workflow:
  //   PENDING_DESIGN = cataloger submitted raw images, awaiting designer
  //   READY          = designer uploaded edited images, product published
  //   null           = not in the design workflow (e.g. pulled from Shopify)
  imageDesignStatus String?

  // Brand & Identity
  brand       String
  subBrand    String?
  label       String?
  productName String?
  modelNo     String?
  fullModelNo String?

  // Frame Attributes (shared across variants)
  shape          String?
  frameMaterial  String?
  templeMaterial String?
  frameType      String?

  // Demographics & Origin
  gender          String?
  countryOfOrigin String?
  warranty        String?

  // Lens Attributes (Sunglasses — shared base)
  lensMaterial String?
  lensUSP      String?
  polarization String?
  uvProtection String?

  // Product USP
  productUSP String?

  // Solutions-specific fields
  recommendedFor String?
  instructions   String?
  ingredients    String?
  benefits       String?
  aboutProduct   String?

  // Base Pricing (default for variants that don't override)
  mrp             Float    @default(0)
  discountedPrice Float    @default(0)
  compareAtPrice  Float    @default(0)

  // Auto-generated fields
  title           String?
  sku             String?  @unique
  seoTitle        String?
  seoDescription  String?
  pageUrl         String?
  tags            String?
  htmlDescription String?

  // Identifiers
  gtin String?
  upc  String?

  // Relations
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  images      ProductImage[]
  locations   ProductLocation[]
  syncLogs    SyncLog[]
  variants    ProductVariant[]
  collections CollectionProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────
// PRODUCT VARIANT = Specific color + size combination
// e.g. BOSS 1234 → variant "086 / 55", "086 / 52", "567 / 55"
// Maps 1:1 to a Shopify Variant.
// ─────────────────────────────────────────────────────────
model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Variant-defining attributes
  colorCode   String   // e.g. "086", "567", "432"
  colorName   String?  // Human-readable: "Black", "Havana", etc.
  frameColor  String?  // Detailed frame color
  templeColor String?
  frameSize   String?  // e.g. "55", "52"
  bridge      String?
  templeLength String?
  weight      String?

  // Lens (may vary by color for sunglasses)
  lensColour String?
  tint       String?

  // Variant-level pricing (overrides parent if set)
  mrp             Float   @default(0)
  discountedPrice Float   @default(0)
  compareAtPrice  Float   @default(0)

  // Auto-generated
  sku     String? @unique  // e.g. "SP-BOSS-1234-086-55"
  barcode String?          // GTIN/UPC for this specific variant
  title   String?          // e.g. "086 / 55" or "Black / 55"

  // Shopify sync
  shopifyVariantId      String?
  shopifyInventoryItemId String?  // Shopify inventory item GID for stock sync

  // Relations
  images    VariantImage[]
  locations VariantLocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, colorCode, frameSize])
}

model VariantImage {
  id             String         @id @default(cuid())
  variantId      String
  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  url            String
  originalUrl    String?
  position       Int            @default(0)
  shopifyMediaId String?
  isProcessed    Boolean        @default(false)
  createdAt      DateTime       @default(now())
}

model VariantLocation {
  id         String         @id @default(cuid())
  variantId  String
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  locationId String
  location   Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  quantity   Int            @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([variantId, locationId])
}

model ProductImage {
  id             String   @id @default(cuid())
  productId      String
  // "RAW"    = uploaded by cataloger, awaiting designer work (not pushed to Shopify)
  // "EDITED" = uploaded by designer, pushed to Shopify (default for back-compat)
  role           String   @default("EDITED")
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url            String
  originalUrl    String?
  position       Int      @default(0)
  shopifyMediaId String?
  isProcessed    Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model ProductLocation {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  quantity   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, locationId])
}

model SyncLog {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  action    String   // CREATE, UPDATE, DELETE, STOCK_UPDATE, VARIANT_CREATE, VARIANT_UPDATE
  status    String   // SUCCESS, FAILED, PENDING
  message   String?
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────
// COLLECTION — synced from Shopify, editable locally
// Maps to Shopify Custom/Smart Collections
// ─────────────────────────────────────────────────────────
model Collection {
  id                   String   @id @default(cuid())
  shopifyCollectionId  String   @unique
  title                String
  handle               String?
  description          String?
  descriptionHtml      String?
  collectionType       String   @default("CUSTOM") // CUSTOM, SMART
  sortOrder            String?  // e.g. BEST_SELLING, ALPHA_ASC, PRICE_DESC, MANUAL
  templateSuffix       String?
  imageUrl             String?
  imageAlt             String?
  seoTitle             String?
  seoDescription       String?
  published            Boolean  @default(true)
  productsCount        Int      @default(0)

  // Smart collection rules (JSON string for SMART collections)
  rules                String?  // JSON array of rules
  disjunctive          Boolean  @default(false) // true = any rule, false = all rules

  // Local edits tracking
  locallyModified      Boolean  @default(false)
  lastSyncedAt         DateTime?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  products             CollectionProduct[]
}

model CollectionProduct {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  position     Int        @default(0)
  createdAt    DateTime   @default(now())

  @@unique([collectionId, productId])
}

// ─────────────────────────────────────────────────────────
// WEBHOOK EVENT — logs incoming Shopify webhook events
// Used for audit trail and debugging real-time sync
// ─────────────────────────────────────────────────────────
model WebhookEvent {
  id        String   @id @default(cuid())
  topic     String   // e.g. "products/update", "orders/create", "inventory_levels/update"
  shopifyId String?  // Shopify resource ID from the event
  payload   String?  // JSON string of the webhook payload (truncated)
  status    String   @default("RECEIVED") // RECEIVED, PROCESSED, FAILED, IGNORED
  message   String?
  createdAt DateTime @default(now())

  @@index([topic, createdAt])
  @@index([shopifyId])
}

// ─────────────────────────────────────────────────────────
// WEBHOOK SUBSCRIPTION — tracks registered webhook subscriptions
// ─────────────────────────────────────────────────────────
model WebhookSubscription {
  id              String   @id @default(cuid())
  shopifyWebhookId String  @unique
  topic           String   // e.g. "PRODUCTS_UPDATE"
  callbackUrl     String
  format          String   @default("JSON")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────
// ORDER — synced from Shopify
// ─────────────────────────────────────────────────────────
model Order {
  id                String   @id @default(cuid())
  shopifyOrderId    String?  @unique
  orderNumber       String?
  name              String?  // e.g. "#1001"
  email             String?
  phone             String?

  // Financials
  totalPrice        Float    @default(0)
  subtotalPrice     Float    @default(0)
  totalTax          Float    @default(0)
  totalDiscount     Float    @default(0)
  currency          String   @default("INR")

  // Status
  financialStatus   String?  // paid, pending, refunded, partially_refunded
  fulfillmentStatus String?  // fulfilled, partial, unfulfilled
  orderStatus       String   @default("OPEN") // OPEN, CLOSED, CANCELLED

  // Customer
  customerId        String?
  customer          Customer? @relation(fields: [customerId], references: [id])

  // Shipping
  shippingAddress   String?  // JSON
  billingAddress    String?  // JSON

  // Meta
  note              String?
  tags              String?
  source            String?  // web, pos, mobile
  cancelReason      String?
  cancelledAt       DateTime?
  closedAt          DateTime?
  processedAt       DateTime?

  // Relations
  lineItems         OrderLineItem[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([orderStatus, createdAt])
  @@index([customerId])
}

model OrderLineItem {
  id              String  @id @default(cuid())
  orderId         String
  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String?
  variantId       String?
  shopifyLineItemId String?
  title           String
  variantTitle    String?
  sku             String?
  quantity        Int     @default(1)
  price           Float   @default(0)
  totalDiscount   Float   @default(0)

  createdAt       DateTime @default(now())

  @@index([orderId])
}

// ─────────────────────────────────────────────────────────
// CUSTOMER — synced from Shopify
// ─────────────────────────────────────────────────────────
model Customer {
  id                String   @id @default(cuid())
  shopifyCustomerId String?  @unique
  email             String?
  phone             String?
  firstName         String?
  lastName          String?

  // Address
  address1          String?
  address2          String?
  city              String?
  state             String?
  zip               String?
  country           String?

  // Stats
  ordersCount       Int      @default(0)
  totalSpent        Float    @default(0)

  // Meta
  tags              String?
  note              String?
  acceptsMarketing  Boolean  @default(false)
  taxExempt         Boolean  @default(false)
  verified          Boolean  @default(false)

  // Relations
  orders            Order[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([email])
  @@index([phone])
}

// ─────────────────────────────────────────────────────────
// STOCK TRANSFER — transfer inventory between locations
// ─────────────────────────────────────────────────────────
model StockTransfer {
  id              String   @id @default(cuid())
  transferNumber  String   @unique
  fromLocationId  String
  toLocationId    String
  status          String   @default("PENDING") // PENDING, IN_TRANSIT, COMPLETED, CANCELLED
  note            String?
  createdById     String?

  items           StockTransferItem[]

  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, createdAt])
}

// ─────────────────────────────────────────────────────────
// ACTIVITY LOG — tracks all user actions in the app
// ─────────────────────────────────────────────────────────
model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  userName    String?
  userEmail   String?
  action      String   // CREATE, UPDATE, DELETE, SYNC, LOGIN, EXPORT, UPLOAD, etc.
  entity      String   // PRODUCT, ORDER, CUSTOMER, COLLECTION, USER, SETTINGS, etc.
  entityId    String?  // ID of the affected entity
  details     String?  // Human-readable description of what changed
  metadata    String?  // JSON string with extra data (old/new values, etc.)
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entity, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}

model StockTransferItem {
  id              String        @id @default(cuid())
  transferId      String
  transfer        StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId       String
  variantId       String?
  productTitle    String?
  variantTitle    String?
  quantity        Int           @default(1)

  createdAt       DateTime      @default(now())

  @@index([transferId])
}
