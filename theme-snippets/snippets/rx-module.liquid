{%- comment -%}
  rx-module.liquid
  ----------------
  Prescription capture module for products tagged `rxable_yes`. The tag is
  set automatically by the bv-app's autoGenerate.ts when the RX-able
  attribute is on (round 2 U5 + 9.5).

  Renders:
    - "Add Prescription" button that opens a modal explainer
    - Per-eye SPH / CYL / AXIS / ADD inputs
    - Single PD or dual PD toggle
    - Prescription image upload (uses Shopify's `file_input`)
    - "Order without prescription" and "Use saved Rx" alternatives

  When the form is filled and submitted, the values are written to the
  cart line-item properties (prefix `_rx_*`) so they flow to Shopify
  orders. The dual / single PD radio toggles which input set is read.

  Pure Liquid + a small <script> for show/hide. No external deps. All
  visual styling is in `assets/theme.css` under `.bv-rx-module` (see
  README).

  Usage:
    {%- render 'rx-module', product: product -%}

  The snippet is self-gating: returns nothing when the product is not
  `rxable_yes` so callers can include it unconditionally.
{%- endcomment -%}

{%- if product.tags contains 'rxable_yes' -%}

  {%- liquid
    assign rx_id = 'bv-rx-' | append: product.id
    assign customer_has_saved_rx = false
    if customer and customer.metafields.bv.saved_rx
      assign customer_has_saved_rx = true
    endif
  -%}

  <div class="bv-rx-module" id="{{ rx_id }}" data-bv-rx-module>
    <h4 class="bv-rx-module__title">Prescription</h4>
    <p class="bv-rx-module__intro">
      This frame is prescription-ready. Add your power below or upload a
      photo of your prescription. Our optical team verifies every order
      before dispatch.
    </p>

    <div class="bv-rx-module__actions">
      <button type="button" class="button button--primary" data-bv-rx-toggle="form" aria-controls="{{ rx_id }}-form">
        Add Prescription
      </button>
      <button type="button" class="button button--secondary" data-bv-rx-toggle="modal" aria-controls="{{ rx_id }}-modal">
        How does this work?
      </button>
      {%- if customer_has_saved_rx -%}
        <button type="button" class="button button--secondary" data-bv-rx-toggle="saved">
          Use my saved prescription
        </button>
      {%- endif -%}
      <button type="button" class="button button--secondary" data-bv-rx-toggle="skip">
        Order without prescription
      </button>
    </div>

    <div class="bv-rx-module__form" id="{{ rx_id }}-form" data-bv-rx-form hidden>
      <div class="bv-rx-module__row">
        <strong>Right Eye (OD)</strong>
      </div>
      <div class="bv-rx-module__grid">
        <span></span>
        <label>SPH</label>
        <label>CYL</label>
        <label>AXIS</label>
        <label>ADD</label>

        <span>OD</span>
        <input type="text" name="properties[_rx_od_sph]" placeholder="-2.00" inputmode="decimal" />
        <input type="text" name="properties[_rx_od_cyl]" placeholder="-0.50" inputmode="decimal" />
        <input type="text" name="properties[_rx_od_axis]" placeholder="180" inputmode="numeric" />
        <input type="text" name="properties[_rx_od_add]" placeholder="+1.00" inputmode="decimal" />

        <span>OS</span>
        <input type="text" name="properties[_rx_os_sph]" placeholder="-2.00" inputmode="decimal" />
        <input type="text" name="properties[_rx_os_cyl]" placeholder="-0.50" inputmode="decimal" />
        <input type="text" name="properties[_rx_os_axis]" placeholder="180" inputmode="numeric" />
        <input type="text" name="properties[_rx_os_add]" placeholder="+1.00" inputmode="decimal" />
      </div>

      <fieldset class="bv-rx-module__pd">
        <legend>Pupillary Distance (PD)</legend>
        <label>
          <input type="radio" name="properties[_rx_pd_mode]" value="single" checked data-bv-pd-mode />
          Single PD
        </label>
        <label>
          <input type="radio" name="properties[_rx_pd_mode]" value="dual" data-bv-pd-mode />
          Dual PD (left / right)
        </label>

        <div class="bv-rx-module__pd-fields" data-bv-pd-single>
          <label>
            PD (mm)
            <input type="text" name="properties[_rx_pd_single]" placeholder="62" inputmode="decimal" />
          </label>
        </div>

        <div class="bv-rx-module__pd-fields" data-bv-pd-dual hidden>
          <label>
            Right PD
            <input type="text" name="properties[_rx_pd_right]" placeholder="31" inputmode="decimal" />
          </label>
          <label>
            Left PD
            <input type="text" name="properties[_rx_pd_left]" placeholder="31" inputmode="decimal" />
          </label>
        </div>
      </fieldset>

      <div class="bv-rx-module__upload">
        <label for="{{ rx_id }}-file">
          Or upload a photo of your prescription (optional)
        </label>
        {{- 'rx_image' | file_input -}}
      </div>

      <input type="hidden" name="properties[_rx_provided]" value="form" data-bv-rx-flag />
    </div>

    {%- comment -%} Hidden flag for "skip" / "saved" so the cart knows. {%- endcomment -%}
    <input type="hidden" name="properties[_rx_status]" value="pending" data-bv-rx-status />

  </div>

  <div class="bv-rx-modal" id="{{ rx_id }}-modal" role="dialog" aria-modal="true" aria-hidden="true" data-bv-rx-modal>
    <div class="bv-rx-modal__inner">
      <h4>How prescription orders work</h4>
      <ol>
        <li>Add your prescription using the form, or upload a photo.</li>
        <li>Our optical team reviews it within 24 hours.</li>
        <li>We craft your lenses to spec and ship pan-India.</li>
        <li>Need help? Call our store at +91-XXXX-XXXXXX.</li>
      </ol>
      <p class="bv-preorder-note">
        Your prescription is stored against this order only and is not
        shared with any third party.
      </p>
      <button type="button" class="button button--secondary" data-bv-rx-close>Close</button>
    </div>
  </div>

  <script>
    (function () {
      var root = document.getElementById({{ rx_id | json }});
      if (!root) { return; }

      function toggleHidden(el, show) {
        if (!el) { return; }
        if (show) { el.removeAttribute('hidden'); }
        else      { el.setAttribute('hidden', 'hidden'); }
      }

      var form   = root.querySelector('[data-bv-rx-form]');
      var modal  = document.getElementById({{ rx_id | append: '-modal' | json }});
      var status = root.querySelector('[data-bv-rx-status]');

      root.addEventListener('click', function (event) {
        var target = event.target.closest('[data-bv-rx-toggle]');
        if (!target) { return; }
        var action = target.getAttribute('data-bv-rx-toggle');

        if (action === 'form') {
          toggleHidden(form, form.hasAttribute('hidden'));
          if (status) { status.value = 'form'; }
        } else if (action === 'modal' && modal) {
          modal.setAttribute('aria-hidden', 'false');
        } else if (action === 'skip') {
          toggleHidden(form, false);
          if (status) { status.value = 'skipped'; }
        } else if (action === 'saved') {
          toggleHidden(form, false);
          if (status) { status.value = 'saved'; }
        }
      });

      if (modal) {
        modal.addEventListener('click', function (event) {
          if (event.target === modal || event.target.matches('[data-bv-rx-close]')) {
            modal.setAttribute('aria-hidden', 'true');
          }
        });
      }

      var pdRadios   = root.querySelectorAll('[data-bv-pd-mode]');
      var pdSingle   = root.querySelector('[data-bv-pd-single]');
      var pdDual     = root.querySelector('[data-bv-pd-dual]');
      pdRadios.forEach(function (radio) {
        radio.addEventListener('change', function () {
          var mode = this.value;
          toggleHidden(pdSingle, mode === 'single');
          toggleHidden(pdDual,   mode === 'dual');
        });
      });
    })();
  </script>

{%- endif -%}
