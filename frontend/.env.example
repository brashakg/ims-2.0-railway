# IMS 2.0 Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# Backend API URL (required for production)
# For local development: http://localhost:8000/api/v1
# For production: https://your-railway-backend.up.railway.app/api/v1
VITE_API_URL=https://ims-20-railway-production.up.railway.app/api/v1

# POS Rx auto-attach (optional, default OFF).
# When "true", the POS Prescription step auto-selects the customer's prescription
# IFF exactly one valid (non-expired) Rx exists and none is attached yet. Leave
# unset/false to keep staff choosing the Rx explicitly.
# VITE_POS_AUTO_ATTACH_SINGLE_RX=false
