# ============================================================================
# IMS 2.0 - Environment Configuration Template
# ============================================================================
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# APPLICATION SETTINGS
# ----------------------------------------------------------------------------
NODE_ENV=production
# Options: development, staging, production

# ----------------------------------------------------------------------------
# BACKEND API SETTINGS
# ----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_URL=http://localhost:8000
# For production: https://your-api-domain.com

# ----------------------------------------------------------------------------
# FRONTEND SETTINGS
# ----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000/api/v1
# For production: https://your-api-domain.com/api/v1

VITE_APP_NAME=IMS 2.0
VITE_APP_VERSION=2.0.0

# ----------------------------------------------------------------------------
# MONGODB DATABASE CONFIGURATION
# ----------------------------------------------------------------------------
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DATABASE=ims_2_0
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_AUTH_SOURCE=admin

# Optional MongoDB Settings
MONGO_REPLICA_SET=
MONGO_SSL=false
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=10

# MongoDB Connection URI (Alternative to individual settings)
# If provided, this will override individual settings above
# MONGODB_URI=mongodb://username:password@host:port/database?authSource=admin

# ----------------------------------------------------------------------------
# JWT AUTHENTICATION
# ----------------------------------------------------------------------------
JWT_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY_IN_PRODUCTION
# Generate a secure key: openssl rand -hex 32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ----------------------------------------------------------------------------
# CORE SECURITY / RUNTIME (REQUIRED IN PROD — names only, set real values in
# Railway; NEVER commit values)
# ----------------------------------------------------------------------------
# Deployment environment. "test" disables rate-limit + seed gates.
ENVIRONMENT=production
# Guards the destructive POST /api/v1/admin/seed-database endpoint. REQUIRED.
SEED_SECRET=
# Fernet key encrypting integration credentials at rest. REQUIRED in prod
# (the integrations config fails loud without it). Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=
# Canonical Mongo connection URI (preferred over the component MONGO_* above).
# MONGODB_URL=
# MONGO_URL=
# Canonical Redis URI (preferred over the component REDIS_* below).
# REDIS_URL=

# ----------------------------------------------------------------------------
# CORS SETTINGS
# ----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# For production: https://your-frontend-domain.com

# ----------------------------------------------------------------------------
# FILE UPLOAD SETTINGS
# ----------------------------------------------------------------------------
MAX_UPLOAD_SIZE=10485760
# 10MB in bytes

UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf

# ----------------------------------------------------------------------------
# EMAIL CONFIGURATION (LEGACY / not currently read by the app — kept for ref)
# ----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@ims2.com
SMTP_USE_TLS=true

# ----------------------------------------------------------------------------
# PAYMENT GATEWAY (Razorpay) — LEGACY env form; these creds are now primarily
# stored in the `integrations` collection and managed via the admin UI.
# ----------------------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# WHATSAPP BUSINESS API (LEGACY — kept for backwards compat; the live inbound
# path uses the WABA_* + MSG91_* vars below)
# ----------------------------------------------------------------------------
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_BUSINESS_NUMBER=

# ----------------------------------------------------------------------------
# WHATSAPP CLOUD API (WABA) — inbound webhook verification (webhooks router)
# ----------------------------------------------------------------------------
WABA_APP_SECRET=
WABA_ACCESS_TOKEN=
WABA_VERIFY_TOKEN=
WABA_PHONE_NUMBER_ID=
WABA_DEFAULT_STORE_ID=

# ----------------------------------------------------------------------------
# MSG91 — outbound WhatsApp + SMS (MEGAPHONE agent; DLT-registered)
# ----------------------------------------------------------------------------
MSG91_API_KEY=
MSG91_SENDER=
MSG91_SMS_TEMPLATE_ID=
MSG91_WHATSAPP_INTEGRATED_NUMBER=
MSG91_WHATSAPP_NAMESPACE=

# ----------------------------------------------------------------------------
# SHOPIFY INTEGRATION — LEGACY env form; now primarily DB-stored in the
# `integrations` collection (NEXUS agent reads from there).
# ----------------------------------------------------------------------------
SHOPIFY_STORE_URL=
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_ACCESS_TOKEN=

# ----------------------------------------------------------------------------
# TALLY INTEGRATION — LEGACY env form; now primarily DB-stored in the
# `integrations` collection.
# ----------------------------------------------------------------------------
TALLY_SERVER_URL=
TALLY_PORT=9000
TALLY_COMPANY_NAME=

# ----------------------------------------------------------------------------
# SHIPROCKET API — LEGACY env form; now primarily DB-stored in the
# `integrations` collection.
# ----------------------------------------------------------------------------
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_API_URL=https://apiv2.shiprocket.in/v1/external

# ----------------------------------------------------------------------------
# AI / JARVIS AGENTS (Claude + LLM provider tuning)
# ----------------------------------------------------------------------------
# Claude API key — ORACLE anomaly narratives + JARVIS chat.
ANTHROPIC_API_KEY=
# Model selection (optional; sensible defaults baked in).
AGENT_CLAUDE_MODEL=
JARVIS_MODEL=
# Optional LLM provider tuning (premium/extra providers, budgets, timeouts).
# LLM_DEFAULT_MODEL=
# LLM_OPUS_ENABLED=
# LLM_TIMEOUT=
# PIXEL — Google PageSpeed Insights (Lighthouse audits) + target URL.
PAGESPEED_API_KEY=
FRONTEND_BASE_URL=

# ----------------------------------------------------------------------------
# OUTBOUND SAFETY GATE (MEGAPHONE + NEXUS writes)
# ----------------------------------------------------------------------------
# off (default) | test | live. Unknown -> off. Default off so a fresh deploy
# never accidentally messages customers.
DISPATCH_MODE=off
# In DISPATCH_MODE=test, the ONLY recipient outbound messages are sent to.
TEST_PHONE=

# ----------------------------------------------------------------------------
# AGENT EVENT BUS
# ----------------------------------------------------------------------------
# Redis pub/sub channel name (default ims.agents.events).
AGENT_EVENT_CHANNEL=

# ----------------------------------------------------------------------------
# WEBHOOKS
# ----------------------------------------------------------------------------
# Anti-replay window in seconds for HMAC-verified inbound webhooks (default 300).
WEBHOOK_REPLAY_WINDOW_SECONDS=300

# ----------------------------------------------------------------------------
# ALERTING (Slack)
# ----------------------------------------------------------------------------
# Incoming-webhook URL for CRITICAL ORACLE anomaly alerts (skipped if unset).
SLACK_WEBHOOK_URL=
# Minimum severity to notify: CRITICAL | HIGH | MEDIUM | LOW (default CRITICAL).
SLACK_ALERT_SEVERITY=CRITICAL

# ----------------------------------------------------------------------------
# MONITORING (Sentry)
# ----------------------------------------------------------------------------
# Get your DSN from https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=
SENTRY_TRACES_RATE=0.2
SENTRY_PROFILES_RATE=0.1

# ----------------------------------------------------------------------------
# LOGGING & MONITORING
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

LOG_FILE=./logs/ims2.log
LOG_MAX_BYTES=10485760
# 10MB
LOG_BACKUP_COUNT=5

# ----------------------------------------------------------------------------
# REDIS (Optional - for caching and sessions)
# ----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ----------------------------------------------------------------------------
# BACKUP CONFIGURATION (LEGACY / not currently read by the app)
# ----------------------------------------------------------------------------
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
# Daily at 2 AM (cron format)
BACKUP_RETENTION_DAYS=30
BACKUP_DIR=./backups

# ----------------------------------------------------------------------------
# SECURITY SETTINGS
# ----------------------------------------------------------------------------
ENABLE_RATE_LIMITING=true
RATE_LIMIT_PER_MINUTE=120

# Session timeout in minutes
SESSION_TIMEOUT=480

# Enable/disable features (LEGACY / not currently read by the app)
ENABLE_API_DOCS=true
# Set to false in production for security

# ----------------------------------------------------------------------------
# BRAND SETTINGS (LEGACY / not currently read by the app — brand identity now
# lives per-entity/store in the org config)
# ----------------------------------------------------------------------------
BRAND_NAME=Better Vision
BRAND_LOGO_URL=/assets/logo.png
BRAND_PRIMARY_COLOR=#CD201A
BRAND_SECONDARY_COLOR=#000000

# ----------------------------------------------------------------------------
# STORE SETTINGS
# ----------------------------------------------------------------------------
DEFAULT_CURRENCY=INR
DEFAULT_TIMEZONE=Asia/Kolkata
DEFAULT_LANGUAGE=en

# ----------------------------------------------------------------------------
# FEATURE FLAGS (LEGACY / not currently read by the app)
# ----------------------------------------------------------------------------
ENABLE_AI_INSIGHTS=false
ENABLE_MARKETPLACE=false
ENABLE_INTEGRATIONS=true
ENABLE_WORKSHOP=true
ENABLE_HR_MODULE=true

# ----------------------------------------------------------------------------
# DEVELOPMENT SETTINGS (LEGACY / not currently read by the app — kept for ref)
# ----------------------------------------------------------------------------
DEBUG=false
RELOAD=false
# Set to true only in development
