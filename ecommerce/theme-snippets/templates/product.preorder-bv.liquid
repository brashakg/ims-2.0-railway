{%- comment -%}
  product.preorder.liquid
  -----------------------
  Alternate product template for pre-order items. Wraps the merchant's
  existing product section but replaces the Add-to-Cart button with an
  "Order Now (ships when available)" button and shows the estimated
  ship date.

  Inventory check is bypassed — the customer can order even when the
  variant is out of stock. Shopify will still capture the order.

  Reads:
    product.metafields.bv.preorder_ship_date -> "Estimated ship date" line.
                                                Accepts a date metafield or
                                                a free-text string.

  Usage:
    Shopify admin -> product -> Theme template -> `product.preorder`
    (round 2 U6).

  Style follows Boost / Dawn-style sections — no inline <style>; see
  README's CSS block for `.bv-preorder-note`.
{%- endcomment -%}

{%- liquid
  assign ship_date = product.metafields.bv.preorder_ship_date | default: ''
  if ship_date.type == 'date' or ship_date.type == 'date_time'
    assign ship_date_display = ship_date | date: '%-d %b %Y'
  else
    assign ship_date_display = ship_date | strip
  endif
-%}

<section class="section section-product section--preorder" data-product-template="preorder">
  <div class="page-width">

    {%- comment -%} Two-column product layout, image gallery + info. {%- endcomment -%}
    <div class="product product--preorder">

      <div class="product__media">
        {%- if product.media.size > 0 -%}
          <div class="product__media-gallery">
            {%- for media in product.media -%}
              <div class="product__media-item" data-index="{{ forloop.index0 }}">
                {%- assign __bv_alt = media.alt | escape -%}{{ media | image_url: width: 1200 | image_tag: alt: __bv_alt, widths: '300,600,900,1200,1800', loading: 'lazy' }}
              </div>
            {%- endfor -%}
          </div>
        {%- else -%}
          {{- 'product-1' | placeholder_svg_tag: 'placeholder-svg' -}}
        {%- endif -%}
      </div>

      <div class="product__info">
        <h1 class="product__title">{{ product.title }}</h1>
        {%- if product.vendor -%}
          <p class="product__vendor">{{ product.vendor }}</p>
        {%- endif -%}

        <div class="product__price">
          {%- if product.compare_at_price > product.price -%}
            <s class="product__price-compare">{{ product.compare_at_price | money }}</s>
          {%- endif -%}
          <span class="product__price-current">{{ product.price | money }}</span>
        </div>

        {%- comment -%}
          Render the badge overlay inline above the form for context (the
          card overlay still renders in collection grids).
        {%- endcomment -%}
        {%- render 'badge-overlay', product: product -%}

        <form method="post" action="/cart/add" enctype="multipart/form-data" class="product-form product-form--preorder">

          {%- comment -%} Variant picker — minimal, theme-aligned. {%- endcomment -%}
          {%- if product.has_only_default_variant == false -%}
            {%- for option in product.options_with_values -%}
              <fieldset class="product-form__option">
                <legend>{{ option.name }}</legend>
                {%- for value in option.values -%}
                  <label>
                    <input type="radio" name="options[{{ option.name | escape }}]" value="{{ value | escape }}"
                      {%- if option.selected_value == value -%} checked {%- endif -%} />
                    {{ value }}
                  </label>
                {%- endfor -%}
              </fieldset>
            {%- endfor -%}
          {%- endif -%}

          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" />
          <input type="hidden" name="properties[_preorder]" value="yes" />
          {%- if ship_date_display != blank -%}
            <input type="hidden" name="properties[Estimated ship date]" value="{{ ship_date_display | escape }}" />
          {%- endif -%}

          <div class="product-form__buttons">
            <button type="submit"
                    class="button button--primary button--full-width"
                    name="add">
              Order Now (ships when available)
            </button>
          </div>

          {%- if ship_date_display != blank -%}
            <p class="bv-preorder-note">
              Estimated ship date: <strong>{{ ship_date_display | escape }}</strong>.
              You'll be charged when you order. We'll email you when the
              item ships.
            </p>
          {%- else -%}
            <p class="bv-preorder-note">
              This is a pre-order item — you'll be charged when you place
              the order, and we'll email you the dispatch update once it
              ships.
            </p>
          {%- endif -%}
        </form>

        <div class="product__description rte">
          {{ product.description }}
        </div>
      </div>
    </div>
  </div>
</section>

{%- comment -%}
  Schema is required for the section to be reorderable in the theme
  editor. Keep it minimal — preorder products inherit visual settings
  from the main `sections/product-template.liquid`.
{%- endcomment -%}
